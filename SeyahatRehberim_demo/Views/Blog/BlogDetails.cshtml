@model SeyahatRehberim_demo.Models.Classes.BlogComment

@{
    ViewData["Title"] = "Blog Detayı";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<link href="~/web2/css/bootstrap.css" rel='stylesheet' type='text/css' />
<link href="~/web2/css/style.css" rel='stylesheet' type='text/css' />

<div class="single" style="padding: 50px 0; background-color: #fcfcfc;">
    <div class="container">

        <div class="col-md-8 single-main">
            <div class="single-grid" style="background: #fff; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); margin-bottom: 40px;">
                @foreach (var item in Model.Value1)
                {
                    <div class="blog-post">
                        <h1 style="font-weight: 800; color: #2c3e50; font-size: 2.5em; margin-top: 0; margin-bottom: 15px; line-height: 1.3;">@item.Title</h1>

                        <div class="blog-meta" style="color: #7f8c8d; font-size: 14px; margin-bottom: 25px; border-bottom: 1px solid #f1f1f1; padding-bottom: 15px;">
                            <span style="margin-right: 20px;"><i class="glyphicon glyphicon-user" style="color: #b33951;"></i> <b>Yazar:</b> @item.Writer</span>
                            <span><i class="glyphicon glyphicon-calendar" style="color: #b33951;"></i> @item.Date.ToString("dd MMMM yyyy")</span>
                        </div>

                        <img src="@Url.Content(item.BlogImage)" class="img-responsive" style="width:100%; border-radius:8px; margin-bottom: 30px; box-shadow: 0 5px 15px rgba(0,0,0,0.08);" alt="@item.Title" />

                        <div class="blog-content" style="font-size: 16px; line-height: 1.9; color: #34495e; text-align: justify; letter-spacing: 0.2px;">
                            @item.Description
                        </div>
                    </div>
                }
            </div>

            <div class="comments-section" style="background: #fff; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); margin-bottom: 40px;">
                <h3 style="margin-top:0; margin-bottom:25px; font-weight:700; color: #2c3e50; border-bottom: 2px solid #b33951; padding-bottom: 10px;">
                    <i class="glyphicon glyphicon-comment" style="font-size: 18px; color: #b33951; margin-right: 5px;"></i> Okuyucu Yorumları
                </h3>

                <ul class="comment-list" style="list-style:none; padding:0; margin:0;">
                    @foreach (var item in Model.Value2)
                    {
                        <li style="display:flex; align-items:flex-start; margin-bottom:25px; background: #fdfdfd; padding: 15px; border-radius: 8px; border-left: 4px solid #b33951;">
                            <img src="~/web2/images/avatar.png" class="img-responsive" style="width:50px; height:50px; border-radius:50%; margin-right:15px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);" alt="Avatar">
                            <div class="desc" style="flex: 1;">
                                <h5 style="font-weight:700; margin-top:0; margin-bottom:5px; color: #34495e;">@item.UserName</h5>
                                <p style="margin:0; color:#555; line-height:1.5; font-size:14px;">@item.CommentText</p>
                            </div>
                        </li>
                    }
                </ul>
            </div>

            <div class="content-form" style="background: #fff; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.04);">
                <h3 style="margin-top:0; margin-bottom:25px; font-weight:700; color: #2c3e50;">Bir Yorum Bırakın</h3>
                <form>
                    <div class="form-group">
                        <input type="text" class="form-control" placeholder="Kullanıcı Adınız" required style="height: 45px; border-radius: 6px; margin-bottom:15px; border: 1px solid #dcdde1;" />
                    </div>
                    <div class="form-group">
                        <input type="email" class="form-control" placeholder="E-Posta Adresiniz" required style="height: 45px; border-radius: 6px; margin-bottom:15px; border: 1px solid #dcdde1;" />
                    </div>
                    <div class="form-group">
                        <textarea class="form-control" placeholder="Deneyiminizi ve düşüncelerinizi buraya yazın..." rows="5" required style="border-radius: 6px; margin-bottom:20px; border: 1px solid #dcdde1; resize: none;"></textarea>
                    </div>
                    <input type="submit" class="btn" value="Yorumu Yayınla" style="padding:12px 35px; background-color:#b33951; color:#fff; border:none; border-radius:6px; font-weight:600; font-size:15px; transition: background 0.2s; width: 100%;" />
                </form>
            </div>
        </div>

        <div class="col-md-4 side-content">
            <div class="recent" style="background: #fff; padding: 25px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); margin-bottom:30px;">
                <h3 style="font-weight: 700; color: #2c3e50; border-bottom:2px solid #b33951; padding-bottom:12px; margin-top: 0; margin-bottom: 15px;">SON YAZILAR</h3>

                <ul style="list-style:none; padding:0; margin:0;">
                    @* Tarihsel olarak (veya ID'ye göre) en yeni 3 yazıyı çekiyoruz *@
                    @foreach (var item in Model.Value3.OrderByDescending(x => x.ID).Take(3))
                    {
                        <li style="padding: 12px 0; border-bottom: 1px solid #f1f1f1;">
                            <a href="/Blog/BlogDetails/@item.ID" style="color:#4a5568; text-decoration:none; font-weight:600; display:block; transition: color 0.2s;" onmouseover="this.style.color='#b33951'" onmouseout="this.style.color='#4a5568'">
                                📝 @item.Title
                            </a>
                        </li>
                    }
                </ul>
            </div>

            <div class="comments" style="background: #fff; padding: 25px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.04);">
                <h3 style="font-weight: 700; color: #2c3e50; border-bottom:2px solid #b33951; padding-bottom:12px; margin-top:0; margin-bottom: 15px;">SON YORUMLAR</h3>
                <ul style="list-style:none; padding:0; margin:0;">
                    @foreach (var item in Model.Value2.OrderByDescending(x => x.ID).Take(3))
                    {
                        <li style="padding: 12px 0; border-bottom: 1px solid #f1f1f1; font-size:14px; color:#4a5568; line-height: 1.5;">
                            <i class="glyphicon glyphicon-comment" style="color: #b33951; margin-right:5px; font-size: 12px;"></i>
                            <b style="color: #2c3e50;">@item.UserName:</b>
                            <span>
                                @if (item.CommentText != null && item.CommentText.Length > 45)
                                {
                                    @item.CommentText.Substring(0, 45)

                                    <text>...</text>
                                }
                                else
                                {
                                    @item.CommentText
                                }
                            </span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="clearfix"></div>
    </div>
</div>