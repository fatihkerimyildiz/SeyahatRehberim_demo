@model SeyahatRehberim_demo.Models.Classes.Destination

@{
    ViewData["Title"] = Model.DestName + " Detayları";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<link href="~/web2/css/bootstrap.css" rel="stylesheet" type="text/css" />
<link href="~/web2/css/style.css" rel="stylesheet" type="text/css" />

<div class="destination-header" style="position: relative; background: url('@Url.Content(Model.DestImage)') no-repeat center center; background-size: cover; height: 350px; border-bottom: 5px solid #b33951;">
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5);"></div>
    <div class="container" style="position: relative; top: 50%; transform: translateY(-50%); text-align: center;">
        <h1 style="color: white; font-weight: 800; font-size: 3.5em; text-shadow: 2px 2px 10px rgba(0,0,0,0.8); margin: 0;">@Model.DestName</h1>
        <p style="color: #f1f1f1; font-size: 1.2em; margin-top: 10px; text-shadow: 1px 1px 5px rgba(0,0,0,0.5);"><i class="glyphicon glyphicon-map-marker" style="color: #b33951;"></i> Muazzam Bir Keşif Rotası</p>
    </div>
</div>

<div class="single" style="padding: 60px 0; background-color: #fcfcfc;">
    <div class="container">

        <div class="row">

            <div class="col-md-3">
                <ul class="nav nav-pills nav-stacked" style="background: #fff; padding: 15px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.04);">
                    <li class="active">
                        <a href="#overview" data-toggle="tab" style="padding: 15px; font-weight: 600; font-size: 15px;"><i class="glyphicon glyphicon-info-sign" style="margin-right: 10px; color: #b33951;"></i> Genel Bakış</a>
                    </li>
                    <li>
                        <a href="#restaurants" data-toggle="tab" style="padding: 15px; font-weight: 600; font-size: 15px;"><i class="glyphicon glyphicon-cutlery" style="margin-right: 10px; color: #b33951;"></i> Restoranlar</a>
                    </li>
                    <li>
                        <a href="#flights" data-toggle="tab" style="padding: 15px; font-weight: 600; font-size: 15px;"><i class="glyphicon glyphicon-plane" style="margin-right: 10px; color: #b33951;"></i> Uçuşlar (Ulaşım)</a>
                    </li>
                    <li>
                        <a href="#activities" data-toggle="tab" style="padding: 15px; font-weight: 600; font-size: 15px;"><i class="glyphicon glyphicon-star" style="margin-right: 10px; color: #b33951;"></i> Aktiviteler</a>
                    </li>
                    <li>
                        <a href="#hotels" data-toggle="tab" style="padding: 15px; font-weight: 600; font-size: 15px;"><i class="glyphicon glyphicon-home" style="margin-right: 10px; color: #b33951;"></i> Konaklama</a>
                    </li>
                </ul>

                <div style="background: #fff; padding: 20px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); margin-top: 20px; text-align: center; border-top: 4px solid #b33951;">
                    <span style="color: #7f8c8d; font-size: 13px; display: block; margin-bottom: 5px;">Tur Başlangıç Fiyatı</span>
                    <h3 style="margin: 0; font-weight: 800; color: #27ae60;">@Model.DestCost.ToString("C0")</h3>
                </div>
            </div>

            <div class="col-md-9">
                <div class="tab-content" style="background: #fff; padding: 40px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); min-height: 410px;">

                    <div class="tab-pane fade in active" id="overview">
                        <h3 style="margin-top: 0; margin-bottom: 20px; font-weight: 700; color: #2c3e50;">📍 @Model.DestName Hakkında</h3>
                        <div style="font-size: 16px; line-height: 1.9; color: #34495e; text-align: justify;">
                            @Model.DestDescription
                        </div>
                    </div>

                    <div class="tab-pane fade" id="restaurants">
                        <h3 style="margin-top: 0; margin-bottom: 20px; font-weight: 700; color: #2c3e50;">🍴 Nerede, Ne Yenir?</h3>
                        <div style="font-size: 15px; line-height: 1.8; color: #555;">
                            <p>Bölgenin en popüler ve köklü lezzet duraklarını sizler için derledik. Tarihi mekanlarda yerel mutfağın en özel yemeklerini deneyimleyebilirsiniz:</p>
                            <ul style="padding-left: 20px; margin-top: 15px;">
                                <li style="margin-bottom: 10px;"><b>Tarihi Konak Restoranı:</b> Yöresel ana yemekler ve otantik atmosfer.</li>
                                <li style="margin-bottom: 10px;"><b>Merkez Lezzet Durağı:</b> Hızlı, güvenilir ve esnaf lokantası kültürünün en iyi temsilcisi.</li>
                            </ul>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="flights">
                        <h3 style="margin-top: 0; margin-bottom: 20px; font-weight: 700; color: #2c3e50;">✈️ Ulaşım ve Uçuş Planı</h3>
                        <p style="font-size: 15px; line-height: 1.8; color: #555; margin-bottom: 25px;">
                            Hayalinizdeki seyahati kesintisiz kılmak için en uygun uçuş seferlerini ve ulaşım alternatiflerini araştırdık. Aşağıdaki bağlantıyı kullanarak doğrudan biletinizi planlayabilirsiniz.
                        </p>
                        <a href="@Model.DestFlight" target="_blank" class="btn" style="background-color: #b33951; color: white; padding: 12px 30px; border-radius: 6px; font-weight: 600; font-size: 15px; display: inline-block;">
                            <i class="glyphicon glyphicon-plane"></i> Pegasus ile Uçuş Seferlerini İncele
                        </a>
                    </div>

                    <div class="tab-pane fade" id="activities">
                        <h3 style="margin-top: 0; margin-bottom: 20px; font-weight: 700; color: #2c3e50;">🎈 Yapılacak En Popüler Aktiviteler</h3>
                        <div style="font-size: 15px; line-height: 1.8; color: #555;">
                            <p>Bu rotayı benzersiz kılacak, tatilinize renk katacak kaçırılmaması gereken deneyimler:</p>
                            <ul style="padding-left: 20px; margin-top: 15px;">
                                <li style="margin-bottom: 10px;">🗺️ <b>Kültür ve Tarih Turları:</b> Yerel rehberler eşliğinde eski şehir sokaklarını ve müzeleri keşfedin.</li>
                                <li style="margin-bottom: 10px;">📸 <b>Fotoğraf Safarisi:</b> Gün doğumu ve gün batımında en güzel manzaraları ölümsüzleştirin.</li>
                            </ul>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="hotels">
                        <h3 style="margin-top: 0; margin-bottom: 20px; font-weight: 700; color: #2c3e50;">🏨 Önerilen Konaklama Tesisleri</h3>
                        <div style="font-size: 15px; line-height: 1.8; color: #555;">
                            <p>Konforunuzdan ödün vermeden bütçenize en uygun, yüksek puanlı ve güvenilir otel alternatifleri:</p>
                            <ul style="padding-left: 20px; margin-top: 15px;">
                                <li style="margin-bottom: 10px;">⭐ <b>Grand Sehir Hotel (5 Yıldız):</b> Şehir merkezinde tam konfor ve spa olanakları.</li>
                                <li style="margin-bottom: 10px;">🏡 <b>Butik Taş Konak Otel:</b> Tarihi dokuyu sonuna kadar hissetmek isteyenler için otantik oda seçenekleri.</li>
                            </ul>
                        </div>
                    </div>

                </div>
            </div>

        </div>

        <div class="clearfix"></div>
    </div>
</div>